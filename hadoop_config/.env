CORE-SITE.XML_hadoop.tmp.dir=/opt/hadoop/data/tmp
CORE-SITE.XML_fs.defaultFS=hdfs://namenode:9000
CORE-SITE.XML_hadoop.proxyuser.hduser.groups=*
CORE-SITE.XML_hadoop.proxyuser.hduser.hosts=*

HDFS-SITE.XML_dfs.replication=1
HDFS-SITE.XML_dfs.blocksize=16777216
HDFS-SITE.XML_dfs.namenode.rpc-bind-host=0.0.0.0
HDFS-SITE.XML_dfs.namenode.rpc-address=namenode:9000
HDFS-SITE.XML_dfs.namenode.servicerpc-bind-host=0.0.0.0
HDFS-SITE.XML_dfs.namenode.http-bind-host=0.0.0.0
HDFS-SITE.XML_dfs.namenode.https-bind-host=0.0.0.0
HDFS-SITE.XML_dfs.permissions=true
HDFS-SITE.XML_dfs.permissions.supergroup=hadoop
HDFS-SITE.XML_dfs.namenode.name.dir=/opt/hadoop/data/nameNode
HDFS-SITE.XML_dfs.datanode.data.dir=/opt/hadoop/data/dataNode
HDFS-SITE.XML_dfs.namenode.safemode.min.datanodes=0
HDFS-SITE.XML_dfs.namenode.safemode.threshold-pct=0.0
HDFS-SITE.XML_dfs.blockreport.initialDelay=0
HDFS-SITE.XML_dfs.heartbeat.interval=3
HDFS-SITE.XML_dfs.namenode.heartbeat.recheck-interval=3000
HDFS-SITE.XML_dfs.webhdfs.enabled=true